# Copy this file to .env (which is gitignored) before running
# `docker compose up --build`.

POSTGRES_DB=enklwiki
POSTGRES_USER=enklwiki
POSTGRES_PASSWORD=change-me

# Any long random string — used to sign editor auth JWTs. Generate one with,
# e.g., `openssl rand -base64 32`.
JWT_SIGNING_KEY=change-me-to-a-long-random-string
